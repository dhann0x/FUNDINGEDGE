# ═══════════════════════════════════════════════════════════════
#  Knights Labs – Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to source control.
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────

# Port the backend listens on (frontend dev server runs on 3000)
PORT=3001

# "development" | "production" | "test"
NODE_ENV=development


# ── Pacifica API ─────────────────────────────────────────────────

# Set to "true" to point all calls at the Pacifica testnet
USE_TESTNET=false

# Mainnet REST base URL (no trailing slash)
PACIFICA_REST_URL=https://api.pacifica.fi/api/v1

# Mainnet WebSocket URL
PACIFICA_WS_URL=wss://ws.pacifica.fi

# Testnet REST base URL
PACIFICA_TESTNET_REST_URL=https://test-api.pacifica.fi/api/v1

# Testnet WebSocket URL
PACIFICA_TESTNET_WS_URL=wss://test-ws.pacifica.fi

# Optional: Pacifica API key for higher WebSocket rate limits
# Leave blank during development – unauthenticated access is fine for hackathon
PACIFICA_API_KEY=


# ── Elfa AI (Social Sentiment) ───────────────────────────────────

# Your Elfa AI API key from the hackathon sponsor portal
# Without this, GET /api/v1/sentiment/:symbol returns 503
ELFA_AI_API_KEY=

# Elfa AI base URL (change only if they publish a new version)
ELFA_AI_BASE_URL=https://api.elfa.ai/v1


# ── CORS ─────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Add your Vercel preview URLs here in production
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ── Cache TTLs (seconds) ─────────────────────────────────────────

# How long to cache live prices (Pacifica pushes updates every ~5 s)
CACHE_PRICES_TTL_S=5

# How long to cache market spec data from /info
CACHE_MARKET_INFO_TTL_S=60

# How long to cache historical funding records
CACHE_HISTORY_TTL_S=30

# How long to cache Elfa AI sentiment results
CACHE_SENTIMENT_TTL_S=120


# ── Statistics & Signal Tuning ────────────────────────────────────

# |z-score| threshold above which a market is flagged as "extreme"
# 2.0 = top/bottom ~2.5% of the distribution (strong signal)
# 1.5 = slightly more sensitive
EXTREME_Z_SCORE_THRESHOLD=2.0

# Minimum hourly rate spread (decimal) to surface an arbitrage pair
# 0.0001 = 0.01%/hr = ~87.6% APY spread on the position
ARBITRAGE_MIN_SPREAD=0.0001

# Maximum number of arbitrage pairs returned by GET /api/v1/arbitrage
ARBITRAGE_MAX_PAIRS=20

# Number of most-recent hourly records used for per-market z-score calc
# 168 = 7 days of hourly data
STATS_HISTORY_WINDOW=168
